    nav a:hover { color: var(--green-light); }
    .nav-phone { color: var(--gold) !important; font-weight: 700 !important; }
    .btn-header {
      background: var(--green-bright); color: white !important; padding: 9px 20px;
      border-radius: 5px; font-size: 13px !important; font-weight: 700 !important;
      letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s !important;
