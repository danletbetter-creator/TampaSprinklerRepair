    .btn-header:hover { background: var(--green-deep) !important; }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: white; border-radius: 2px; transition: all 0.3s; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      position: relative; overflow: hidden;
      background: var(--blue-deep);
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 65% 50%, rgba(35,65,160,0.6) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 5% 70%, rgba(45,160,82,0.2) 0%, transparent 60%),
        linear-gradient(135deg, #0c1840 0%, #1a2e6b 55%, #0e2050 100%);
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(107,143,224,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(107,143,224,0.05) 1px, transparent 1px);
      background-size: 64px 64px;
    }
    /* Decorative circle accent */
    .hero-circle {
      position: absolute; right: -80px; top: 50%; transform: translateY(-50%);
      width: 600px; height: 600px; border-radius: 50%;
      border: 1px solid rgba(107,143,224,0.12);
      pointer-events: none;
    }
    .hero-circle::before {
      content: ''; position: absolute; inset: 40px; border-radius: 50%;
      border: 1px solid rgba(45,160,82,0.1);
    }

    .hero-content {
      position: relative; z-index: 2; max-width: 1200px; margin: 0 auto;
      padding: 120px 40px 80px;
      display: grid; grid-template-columns: 1fr 400px; gap: 64px; align-items: center; width: 100%;
    }

