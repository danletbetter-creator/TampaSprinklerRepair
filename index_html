      letter-spacing: 0.05em; text-transform: uppercase; border-radius: 5px;
      border: 2px solid rgba(255,255,255,0.25); transition: all 0.25s;
    }
    .btn-secondary:hover { border-color: var(--green-light); color: var(--green-light); }

    .hero-stats {
      display: flex; gap: 32px; margin-top: 52px; padding-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.1);
      animation: fadeUp 0.6s 0.4s ease both;
    }
    .stat { display: flex; flex-direction: column; }
    .stat-num { font-family: 'Playfair Display', serif; font-size: 30px; font-weight: 700; color: var(--green-light); line-height: 1; }
    .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.06em; text-transform: uppercase; margin-top: 4px; }

    /* Hero card */
    .hero-card {
      background: rgba(255,255,255,0.06); backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.12); border-radius: 18px;
      padding: 36px; animation: fadeUp 0.7s 0.3s ease both;
    }
    .hero-card-logo { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
    .hero-card-logo img { width: 56px; height: 56px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.15); }
    .hero-card h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: white; margin-bottom: 4px; }
    .hero-card p { font-size: 12px; color: rgba(255,255,255,0.45); margin-bottom: 20px; }

    .contact-form input,
    .contact-form textarea {
      width: 100%; background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12); border-radius: 7px;
      padding: 12px 15px; color: white; font-family: 'DM Sans', sans-serif;
      font-size: 14px; margin-bottom: 11px; outline: none; transition: border-color 0.2s;
    }
    .contact-form input::placeholder, .contact-form textarea::placeholder { color: rgba(255,255,255,0.3); }
    .contact-form input:focus, .contact-form textarea:focus { border-color: var(--green-light); }
    .contact-form textarea { resize: none; height: 84px; }
