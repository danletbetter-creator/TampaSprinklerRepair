  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-deep: #1a2e6b;
      --blue-mid: #2341a0;
      --blue-bright: #2f55c8;
      --blue-light: #6b8fe0;
      --green-deep: #1a5c32;
      --green-mid: #237a44;
      --green-bright: #2da052;
      --green-light: #5dc47a;
      --gold: #f0c040;
      --cream: #f4f7ff;
      --white: #ffffff;
      --dark: #0e1a3a;
      --gray: #5a6a8a;
      --gray-light: #e2e8f8;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--dark);
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 0 40px; height: 76px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(26, 46, 107, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(107,143,224,0.2);
      box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo img { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.2); }
    .logo-text { display: flex; flex-direction: column; line-height: 1.15; }
    .logo-text span:first-child {
      font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700;
      color: var(--white); letter-spacing: 0.02em;
    }
    .logo-text span:last-child {
      font-size: 10px; color: var(--green-light); letter-spacing: 0.12em;
      text-transform: uppercase; font-weight: 600;
    }

    nav { display: flex; align-items: center; gap: 28px; }
    nav a {
      color: rgba(255,255,255,0.75); text-decoration: none;
      font-size: 14px; font-weight: 500; letter-spacing: 0.03em; transition: color 0.2s;
