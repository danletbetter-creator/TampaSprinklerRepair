    .section-intro { font-size: 16px; line-height: 1.75; color: var(--gray); max-width: 580px; font-weight: 300; }

    /* ── WHY ── */
    .why-section { background: var(--white); }
    .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; margin-top: 56px; }

    .why-reasons { display: flex; flex-direction: column; gap: 18px; margin-top: 36px; }
